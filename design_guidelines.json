  "instructions_to_main_agent": [
    "1. SETUP: Create 'src/constants/Colors.ts' and 'src/constants/Layout.ts' implementing the values above.",
    "2. FONTS: Use 'expo-font' to load 'Outfit' and 'Inter'. If these specific fonts fail to load, fallback to System fonts immediately to avoid crashes.",
    "3. STYLING: Do NOT use Tailwind classes (className='...'). Use StyleSheet.create({}) or inline styles with the constants defined.",
    "4. COMPONENTS: Create reusable 'Button.tsx', 'Input.tsx', 'Card.tsx' in 'src/components/ui/' based on the component styles defined above.",
    "5. SAFE AREA: Always wrap screen content in <SafeAreaView> from 'react-native-safe-area-context'.",
    "6. KEYBOARDS: Use <KeyboardAvoidingView> with behavior='padding' on iOS and 'height' on Android for all forms.",
    "7. NAVIGATION: Use 'expo-router'. Create a Layout file for the tabs.",
    "8. THEME: Implement a ThemeContext or use React Navigation's theme prop to handle Light/Dark mode toggling.",
    "9. ANIMATION: Use 'react-native-reanimated' for layout transitions (entering={FadeInDown})."
  ],
  "UNIVERSAL_GUIDELINES": [
    "Avoid generic 'SaaS Blue' gradients. Use solid, authoritative colors.",
    "Ensure touch targets are at least 44x44 points.",
    "Use 1px borders for separation, not just whitespace, to improve contrast in bright sunlight.",
    "Data fields (prices, dates) should use Monospace font or tabular nums for alignment."
  ]
